# PPDO Portal — Frontend environment variables
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and must NEVER be committed.

# Azure Functions API base URL
# - Local dev (no SWA CLI): http://localhost:7071/api
# - Local dev (with SWA CLI on :4280): /api
# - Production (Azure SWA): /api   ← SWA proxies /api/* to linked Functions app
NEXT_PUBLIC_API_BASE_URL=http://localhost:7071/api
