{
  "version": "2.0",
  "cors": {
    "allowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4280"
    ],
    "supportCredentials": true
  },
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensions": {
    "http": {
      "routePrefix": "api"
    }
  }
}
